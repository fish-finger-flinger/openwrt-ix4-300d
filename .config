# OpenWrt Configuration for Marvell Armada XP (IX4-300d)
# Target: mvebu/armada-xp

CONFIG_TARGET_mvebu=y
CONFIG_TARGET_mvebu_armada-xp=y
CONFIG_TARGET_mvebu_armada-xp_DEVICE_lenovo_ix4-300d=y

# NAND Flash Support
CONFIG_MTD=y
CONFIG_MTD_NAND_ECC=y
CONFIG_MTD_NAND_ECC_SW_HAMMING=y
CONFIG_MTD_NAND_IDS=y
CONFIG_MTD_NAND_PXA3xx=y
CONFIG_MTD_UBI=y
CONFIG_MTD_UBIFS=y

# Storage / SATA Support
CONFIG_SCSI=y
CONFIG_SCSI_LOWLEVEL=y
CONFIG_ATA=y
CONFIG_SATA_MV=y
CONFIG_SATA_AHCI=y
CONFIG_SCSI_DISK=y

# USB Support
CONFIG_USB=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_XHCI_HCD=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_INET6=y
CONFIG_IPV6=y

# Ethernet (Marvell 88E1318)
CONFIG_PHYLIB=y
CONFIG_MARVELL_PHY=y
CONFIG_NET_VENDOR_MARVELL=y
CONFIG_MVNETA=y

# GPIO Support
CONFIG_GPIO=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_MVEBU=y

# GPIO LEDs and Buttons
CONFIG_LEDS_GPIO=y
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y

# I2C Support
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_MV64XXX=y

# RTC (NXP pcf8563)
CONFIG_RTC_CLASS=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_DRV_PCF8563=y

# Hardware Monitoring (ADT7473)
CONFIG_HWMON=y
CONFIG_SENSORS_ADT7473=y
CONFIG_THERMAL=y

# Filesystem Options
CONFIG_EXT4_FS=y
CONFIG_SQUASHFS=y
CONFIG_VFAT_FS=m

# Serial Console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y
